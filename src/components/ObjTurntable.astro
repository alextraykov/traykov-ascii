---
type Props = {
  class?: string;
  asciiClass?: string;
  name?: string;
  objSrc: string;
  hoverOnly?: boolean;
  playgroundKey?: string;
  renderSize?: number;
  density?: number;
  glyphDetail?: number;
  contrast?: number;
  brightness?: number;
  hover?: number;
  click?: number;
  glow?: number;
  enableReveal?: number;
  revealDuration?: number;
  revealScatter?: number;
  enableDisperse?: number;
  disperse?: number;
  magnetism?: number;
  disperseRadius?: number;
  trailDecay?: number;
  enableExplosion?: number;
  explosion?: number;
  explosionRadius?: number;
  ripple?: number;
  enableColorClick?: number;
  colorClick?: number;
  enableColorDisperse?: number;
  colorDisperse?: number;
  staticAscii?: string;
  ariaLabel?: string;
};

const {
  class: className = "",
  asciiClass = "",
  name = "obj",
  objSrc,
  hoverOnly = false,
  playgroundKey,
  renderSize,
  density,
  glyphDetail,
  contrast,
  brightness,
  hover,
  click,
  glow,
  enableReveal,
  revealDuration,
  revealScatter,
  enableDisperse,
  disperse,
  magnetism,
  disperseRadius,
  trailDecay,
  enableExplosion,
  explosion,
  explosionRadius,
  ripple,
  enableColorClick,
  colorClick,
  enableColorDisperse,
  colorDisperse,
  staticAscii = "",
  ariaLabel = `${name} 3D ASCII turntable`
} = Astro.props;

const classes = [className, hoverOnly ? "has-hover-turntable" : ""].filter(Boolean).join(" ");
const asciiClasses = [staticAscii ? "project-turntable__ascii" : "", asciiClass].filter(Boolean).join(" ") || undefined;
const showSkeleton = asciiClass.split(/\s+/).includes("about-turntable__ascii");
const skeletonClasses = [asciiClasses, "obj-turntable__skeleton"].filter(Boolean).join(" ");
---

<div
  class={classes}
  data-obj-turntable
  data-turntable-name={name}
  data-obj-src={objSrc}
  data-hover-turntable={hoverOnly ? true : undefined}
  data-playground-turntable={playgroundKey}
  data-render-size={renderSize}
  data-card-density={density}
  data-card-glyph-detail={glyphDetail}
  data-card-contrast={contrast}
  data-card-brightness={brightness}
  data-card-hover={hover}
  data-card-click={click}
  data-card-glow={glow}
  data-card-enable-reveal={enableReveal}
  data-card-reveal-duration={revealDuration}
  data-card-reveal-scatter={revealScatter}
  data-card-enable-disperse={enableDisperse}
  data-card-disperse={disperse}
  data-card-magnetism={magnetism}
  data-card-disperse-radius={disperseRadius}
  data-card-trail-decay={trailDecay}
  data-card-enable-explosion={enableExplosion}
  data-card-explosion={explosion}
  data-card-explosion-radius={explosionRadius}
  data-card-ripple={ripple}
  data-card-enable-color-click={enableColorClick}
  data-card-color-click={colorClick}
  data-card-enable-color-disperse={enableColorDisperse}
  data-card-color-disperse={colorDisperse}
  role={ariaLabel ? "img" : undefined}
  aria-label={ariaLabel}
  aria-hidden={ariaLabel ? undefined : "true"}
>
  {staticAscii && <pre class="project-turntable__static" aria-hidden="true">{staticAscii}</pre>}
  {showSkeleton && <pre class={skeletonClasses} data-obj-skeleton aria-hidden="true"></pre>}
  <pre class={asciiClasses} data-obj-ascii aria-hidden="true">{staticAscii}</pre>
</div>
