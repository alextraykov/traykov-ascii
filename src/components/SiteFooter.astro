---
type FooterLink = {
  label: string;
  href: string;
  external?: boolean;
};

const {
  links = [],
  statement = "Designing product systems for AI-native tools and complex software."
}: {
  links?: FooterLink[];
  statement?: string;
} = Astro.props;

const year = new Date().getFullYear();
const currentPath = Astro.url.pathname;
const siteLinks: FooterLink[] = [
  { label: "Work", href: "/case-studies/" },
  { label: "About", href: "/about/" },
  { label: "Playground", href: "/playground" },
  { label: "Studio", href: "/svg-ascii-studio/" }
];
const socialLinks: FooterLink[] = [
  { label: "LinkedIn", href: "https://www.linkedin.com/in/alextraykov/", external: true },
  { label: "Twitter", href: "https://twitter.com/alextraykov", external: true }
];
---

<footer id="contact" class="site-footer">
  <div class="site-footer__inner section-shell">
    <div class="site-footer__mast" data-reveal="fade">
      <a class="site-footer__mark" href={`${currentPath}#top`} aria-label="Back to top">
        <span data-scramble data-footer-scramble data-scramble-label="AT">AT</span>
      </a>
      <p>{statement}</p>
    </div>

    <nav class="footer-links" aria-label="Footer" data-reveal-group>
      <div class="footer-links__group">
        <span>Site</span>
        {siteLinks.map((link) => (
          <a href={link.href} aria-label={link.label}>
            <span data-scramble data-scramble-label={link.label}>{link.label}</span>
          </a>
        ))}
      </div>

      <div class="footer-links__group">
        <span>Elsewhere</span>
        {socialLinks.map((link) => (
          <a
            href={link.href}
            aria-label={link.label}
            target={link.external ? "_blank" : undefined}
            rel={link.external ? "noreferrer" : undefined}
          >
            <span data-scramble data-scramble-label={link.label}>{link.label}</span>
          </a>
        ))}
      </div>

      {links.length > 0 && (
        <div class="footer-links__group">
          <span>Current</span>
          {links.map((link) => (
            <a
              href={link.href}
              aria-label={link.label}
              target={link.external ? "_blank" : undefined}
              rel={link.external ? "noreferrer" : undefined}
            >
              <span data-scramble data-scramble-label={link.label}>{link.label}</span>
            </a>
          ))}
        </div>
      )}
    </nav>

    <div class="site-footer__meta" aria-label="Footer details" data-reveal-group>
      <span>Alexander Traykov</span>
      <span>Sofia, Bulgaria</span>
      <span>{year}</span>
      <a href={`${currentPath}#top`} aria-label="Back to top">
        <span data-scramble data-scramble-label="Back to top">Back top</span>
      </a>
    </div>
  </div>
</footer>

<script>
  import "../scripts/motion/index.js";
</script>
