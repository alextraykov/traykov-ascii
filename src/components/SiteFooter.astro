---
type FooterLink = {
  label: string;
  href: string;
  external?: boolean;
};

const {
  links = [],
  bookingUrl =
    import.meta.env.PUBLIC_CAL_BOOKING_URL ??
    import.meta.env.PUBLIC_BOOKING_URL ??
    "https://cal.com/alexander-cqn5aq/30min"
}: {
  links?: FooterLink[];
  bookingUrl?: string;
} = Astro.props;

const currentPath = Astro.url.pathname;
const siteLinks: FooterLink[] = [
  { label: "Work", href: "/#work" },
  { label: "About", href: "/about/" },
  { label: "Contact", href: "/contact/" },
  { label: "Labs", href: "/playground" },
  { label: "Turntable editor", href: "/svg-ascii-studio/" },
  { label: "Notes", href: "https://alexandertraykov.substack.com/", external: true }
];
const socialLinks: FooterLink[] = [
  { label: "Email hi@traykov.cc", href: "mailto:hi@traykov.cc" },
  { label: "Book a call", href: bookingUrl, external: true }
];

const bookingPageUrl = (() => {
  try {
    const url = new URL(bookingUrl);
    return ["https:", "http:"].includes(url.protocol) ? url.toString() : undefined;
  } catch {
    return undefined;
  }
})();

const bookingEmbedUrl = (() => {
  if (!bookingPageUrl) return undefined;

  const url = new URL(bookingPageUrl);
  const isCalBooking =
    url.hostname === "cal.com" &&
    url.pathname.split("/").filter(Boolean).length >= 2;
  if (!isCalBooking) return undefined;

  url.searchParams.set("embed", "true");
  return url.toString();
})();
---

<footer id="contact" class="site-footer">
  <div class="site-footer__inner section-shell">
    <section class="site-footer__booking" aria-labelledby="footer-booking-title" data-reveal="rise">
      <div class="site-footer__booking-copy">
        <h2 id="footer-booking-title">Book a call</h2>
        <p>Thirty minutes. No pitch, no pressure.</p>
      </div>

      {bookingEmbedUrl ? (
        <>
          <button
            id="book-a-call"
            class="footer-booking__trigger"
            type="button"
            aria-haspopup="dialog"
            data-footer-booking-open
            data-booking-modal-open
            data-ascii-action="primary"
            data-ascii-stream
            data-ascii-burst
          >
            <span data-scramble data-scramble-label="Book a call">Book a call</span>
            <span class="footer-booking__icon" aria-hidden="true">+</span>
          </button>
          <dialog class="footer-booking-modal" aria-labelledby="footer-booking-modal-title" data-footer-booking-modal>
            <div class="footer-booking-modal__header">
              <div>
                <span>30 focused minutes</span>
                <h2 id="footer-booking-modal-title">Pick a time that works.</h2>
              </div>
              <button
                type="button"
                class="footer-booking-modal__close"
              aria-label="Close booking calendar"
              data-footer-booking-close
              data-ascii-burst
              >
                <span aria-hidden="true">×</span>
              </button>
            </div>
            <div class="footer-booking__body">
              <iframe
                class="footer-booking__frame"
                src={bookingEmbedUrl}
                title="Book a 30-minute call with Alexander Traykov"
                loading="lazy"
                allow="payment"
              ></iframe>
              <p class="footer-booking__fallback">
                If the calendar does not load,
                <a href={bookingPageUrl} target="_blank" rel="noreferrer">open the booking page ↗</a>
              </p>
            </div>
          </dialog>
        </>
      ) : (
        <a class="site-footer__booking-action" href="mailto:hi@traykov.cc?subject=30-minute%20product%20call">
          Email me about a call
        </a>
      )}
    </section>

    <div class="site-footer__mast" data-reveal="fade">
      <a class="site-footer__mark" href={`${currentPath}#top`} aria-label="Back to top">
        <span class="site-footer__mark-logo" aria-hidden="true"></span>
      </a>
    </div>

    <nav class="footer-links" aria-label="Footer" data-reveal-group>
      <div class="footer-links__group">
        <span>Site</span>
        {siteLinks.map((link) => (
          <a
            href={link.href}
            aria-label={link.label}
            target={link.external ? "_blank" : undefined}
            rel={link.external ? "noreferrer" : undefined}
          >
            <span data-scramble data-scramble-label={link.label}>{link.label}</span>
          </a>
        ))}
      </div>

      <div class="footer-links__group">
        <span>Contact</span>
        {socialLinks.map((link) => (
          <a
            href={link.href}
            aria-label={link.label}
            target={link.external ? "_blank" : undefined}
            rel={link.external ? "noreferrer" : undefined}
          >
            <span data-scramble data-scramble-label={link.label}>{link.label}</span>
          </a>
        ))}
      </div>

      {links.length > 0 && (
        <div class="footer-links__group">
          <span>Current</span>
          {links.map((link) => (
            <a
              href={link.href}
              aria-label={link.label}
              target={link.external ? "_blank" : undefined}
              rel={link.external ? "noreferrer" : undefined}
            >
              <span data-scramble data-scramble-label={link.label}>{link.label}</span>
            </a>
          ))}
        </div>
      )}
    </nav>

    <div class="site-footer__meta" aria-label="Footer details">
      <span>Ideated, designed and prompted in Sofia, Bulgaria 2026</span>
      <a href={`${currentPath}#top`} aria-label="Back to top">
        <span data-scramble data-scramble-label="Back to top">Back top</span>
      </a>
    </div>
  </div>
</footer>

<script>
  import "../scripts/motion/index.js";

  document.querySelectorAll("[data-footer-booking-modal]").forEach((modal) => {
    if (!(modal instanceof HTMLDialogElement) || modal.dataset.bookingReady === "true") return;

    const closeButton = modal.querySelector("[data-footer-booking-close]");
    if (!(closeButton instanceof HTMLButtonElement)) return;

    modal.dataset.bookingReady = "true";
    let activeTrigger: HTMLElement | null = null;
    document.querySelectorAll<HTMLElement>("[data-booking-modal-open]").forEach((trigger) => {
      trigger.addEventListener("click", (event) => {
        event.preventDefault();
        activeTrigger = trigger;
        modal.showModal();
      });
    });
    closeButton.addEventListener("click", () => modal.close());
    modal.addEventListener("click", (event) => {
      if (event.target === modal) modal.close();
    });
    modal.addEventListener("close", () => activeTrigger?.focus());
  });
</script>
