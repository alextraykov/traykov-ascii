---
type Props = {
  title?: string;
  description?: string;
  path?: string;
  image?: string;
  noindex?: boolean;
  refresh?: string;
};

const {
  title = "Alexander Traykov - Product Design Portfolio",
  description = "Product design portfolio of Alexander Traykov, focused on AI product surfaces, design systems, and complex software.",
  path = Astro.url.pathname,
  image = "/og-image.png",
  noindex = false,
  refresh
}: Props = Astro.props;

const siteUrl = "https://traykov.cc";
const canonicalUrl = new URL(path, siteUrl).toString();
const imageUrl = new URL(image, siteUrl).toString();
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
{noindex && <meta name="robots" content="noindex, nofollow" />}
{refresh && <meta http-equiv="refresh" content={refresh} />}
<link rel="canonical" href={canonicalUrl} />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="theme-color" content="#080808" />
<meta property="og:site_name" content="Alexander Traykov" />
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={imageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="Alexander Traykov product design portfolio preview" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
