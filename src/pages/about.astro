---
import SiteAnalytics from "../components/SiteAnalytics.astro";
import DitherImageTrail from "../components/DitherImageTrail.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHead from "../components/SiteHead.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import { imageTrailImages } from "../lib/image-trail";
import "../styles/global.css";

const experience = [
  {
    role: "UX Team Lead",
    company: "Quickbase",
    period: "July 2023 - Current",
    body:
      "I lead UX work at Quickbase while staying involved in product design. I also run critiques, help set priorities, and support designers as they learn a domain or take on harder work."
  },
  {
    role: "Senior Product Designer",
    company: "Quickbase",
    period: "July 2022 - July 2023",
    body:
      "I worked on Quickbase’s Solution Hub and led design for one of the company’s largest projects in 2022, working closely with product and engineering from early research through delivery."
  },
  {
    role: "Senior Product Designer",
    company: "PeakShift",
    period: "January 2022 - June 2022",
    body:
      "I helped with hiring, research, and design marketing while working on bolt.fun, Alby, and BTC Payer."
  },
  {
    role: "Product Designer",
    company: "Toptal",
    period: "April 2019 - January 2022",
    body:
      "Designed for staff experience and internal tools, with a focus on operational workflows used by Toptal teams."
  },
  {
    role: "Product Designer",
    company: "MarketVision Consulting Group",
    period: "August 2018 - April 2019",
    body:
      "Created mobile design systems for iOS and Android, redesigned desktop component systems, and worked across research, analytics, usability, product improvements, and UI copy."
  },
  {
    role: "Product Designer",
    company: "eAssist",
    period: "January 2018 - August 2018",
    body:
      "Worked across data analytics products, dashboards, and marketing websites for a business process outsourcing company."
  },
  {
    role: "Product Designer",
    company: "Pruvit",
    period: "May 2017 - January 2018",
    body:
      "Designed and maintained component systems for iOS and Android applications in an iteration-heavy product process."
  },
  {
    role: "UI/UX Designer",
    company: "Canbrowser",
    period: "April 2017 - April 2018",
    body:
      "Redesigned a complex private software initiative supporting the CAN industry.",
    href: "https://canbrowser.com/"
  },
  {
    role: "UI/UX Designer",
    company: "Noxious.one",
    period: "July 2016 - November 2016",
    body:
      "Worked on CMS products, mobile app design, wireframing, prototyping, and early product ideation.",
    href: "https://noxious.one/"
  },
  {
    role: "Junior UI/UX Designer",
    company: "Kickflip",
    period: "August 2015 - December 2015",
    body:
      "Designed graphic material for HealthXL and worked on a website for Obecto, one of Bulgaria’s largest software development companies.",
    href: "https://kickflip.digital"
  },
  {
    role: "Junior Web Designer",
    company: "Stenik",
    period: "December 2014 - April 2015",
    body:
      "Designed eCommerce work for leading Bulgarian brands, including the largest cinema eCommerce website in Bulgaria.",
    href: "https://www.stenikgroup.com/en/"
  }
];

const metrics = [
  {
    value: "150K+",
    label: "Product reach across work"
  },
  {
    value: "20+",
    label: "Products"
  },
  {
    value: "10",
    label: "Orgs and product teams"
  },
  {
    value: "13",
    label: "Years doing design"
  }
];

const writingAndInterviews = [
  {
    eyebrow: "Interview / Mode Remote",
    title: "A conversation with Mode Remote",
    body: "An interview about my path into product design, the work behind the work, and what I have learned along the way.",
    href: "https://moderemote.com/interviews/alexander-traykov",
    cta: "Read the interview"
  },
  {
    eyebrow: "Writing / Substack",
    title: "Notes from Alexander Traykov",
    body: "Essays and working notes on product design, teams, craft, and the ideas I keep returning to.",
    href: "https://alexandertraykov.substack.com/",
    cta: "Read my writing"
  }
];

---

<!doctype html>
<html lang="en">
  <head>
    <SiteHead
      title="Alexander Traykov"
      description="Alexander Traykov is a human building things with the help of machines."
      path="/about/"
    />
    <script src="/page-transitions.js" defer></script>
  </head>
  <body data-page-type="about">

    <header class="site-nav">
      <a class="brand" href="/" aria-label="Alexander Traykov home">AT</a>
      <nav aria-label="Primary">
        <a href="/#work" data-scramble>Work</a>
        <a href="/about/" aria-current="page" data-scramble>About</a>
        <a href="/contact/" data-scramble>Contact</a>
      </nav>
      <ThemeToggle />
    </header>

    <main id="top" class="about-page">
      <section class="about-hero about-hero--trail" aria-labelledby="about-title">
        <DitherImageTrail
          images={imageTrailImages}
          label="Interactive ASCII gallery from Alexander's life and work"
        />
        <div class="about-hero-copy">
          <h1 id="about-title" class="about-title about-title--trail">
            <span>A human building things</span>
            <span>with the help of machines</span>
          </h1>
        </div>
      </section>

      <section id="metrics" class="about-metrics" aria-label="Selected career and product metrics" data-reveal="rise">
        <div class="about-metrics__inner section-shell" data-reveal-group>
          {metrics.map((metric) => (
            <article class="about-metric">
              <strong>{metric.value}</strong>
              <p>{metric.label}</p>
            </article>
          ))}
        </div>
        <span class="about-metrics__roughly">Roughly*</span>
      </section>

      <section class="about-grid section-shell" aria-labelledby="story-title" data-reveal="rise">
        <div class="about-copy">
          <h2 id="story-title">Greetings, friends.</h2>
          <p>
            I’m Alexander and I am a human. I take care of my three kids, do my best to be a good husband, and for the past 13 years I’ve been doing a lot of design.
          </p>
          <p>
            Right now at Quickbase I do tons of things: leadership, management, and high-quality IC work. I’m <span class="about-nerd-burst" tabindex="0"><span class="about-nerd-burst__text">absolutely geeking tf out</span><span class="about-nerd-burst__emoji" aria-hidden="true">🤓</span><span class="about-nerd-burst__emoji" aria-hidden="true">🧠</span><span class="about-nerd-burst__emoji" aria-hidden="true">⚡</span><span class="about-nerd-burst__emoji" aria-hidden="true">🤖</span><span class="about-nerd-burst__emoji" aria-hidden="true">💻</span><span class="about-nerd-burst__emoji" aria-hidden="true">🧪</span><span class="about-nerd-burst__emoji" aria-hidden="true">👾</span><span class="about-nerd-burst__emoji" aria-hidden="true">🫠</span></span> when a discussion about AI starts.
          </p>
          <p>
            At 17, my teacher trusted me with a Sofia Philharmonic poster. Seeing it around the city made design feel like a real job. I’ve followed that thread from eCommerce and mobile to automation and AI.
          </p>
          <p>
            Outside work, I’m an energetic, underslept father. I hike, bike, fight under controlled conditions (martial arts), drink too much coffee, and try to make my wife and kids laugh.
          </p>
        </div>
      </section>

      <section id="experience" class="about-experience section-shell" aria-labelledby="experience-title" data-reveal="rise">
        <div class="section-heading">
          <p class="section-kicker">Work experience</p>
          <h2 id="experience-title">The whole path, not just the recent bit.</h2>
        </div>

        <div class="experience-list" data-reveal-group>
          {experience.map((item) => (
            <article class="experience-item">
              <div>
                <p>{item.period}</p>
                <h3>{item.company} - {item.role}</h3>
              </div>
              <div>
                <p>{item.body}</p>
                {item.href && <a href={item.href} target="_blank" rel="noreferrer">Visit</a>}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="writing" class="about-published section-shell" aria-labelledby="published-title" data-reveal="rise">
        <div class="section-heading">
          <p class="section-kicker">Writing &amp; interviews</p>
          <h2 id="published-title">Things I’ve written and talked about.</h2>
        </div>

        <div class="published-list" data-reveal-group>
          {writingAndInterviews.map((item) => (
            <article class="published-item">
              <p class="published-item__eyebrow">{item.eyebrow}</p>
              <h3>{item.title}</h3>
              <p class="published-item__body">{item.body}</p>
              <a href={item.href} target="_blank" rel="noreferrer">
                <span data-scramble data-scramble-label={item.cta}>{item.cta}</span>
                <span aria-hidden="true">↗</span>
              </a>
            </article>
          ))}
        </div>
      </section>
    </main>

    <SiteFooter />
    <SiteAnalytics />
  </body>
</html>
