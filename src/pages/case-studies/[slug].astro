---
import CaseContactPrompt from "../../components/CaseContactPrompt.astro";
import PaveTurntable from "../../components/PaveTurntable.astro";
import SiteAnalytics from "../../components/SiteAnalytics.astro";
import SiteHead from "../../components/SiteHead.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import SynapseSysTurntable from "../../components/SynapseSysTurntable.astro";
import ThemeToggle from "../../components/ThemeToggle.astro";
import { getCaseStudies, getCaseStudyHeadings, renderMarkdown } from "../../lib/content";
import { getPublicCaseStudies, isPublicCaseStudy } from "../../lib/public-case-studies";
import "../../styles/global.css";

export function getStaticPaths() {
  const studies = getCaseStudies();
  const publicStudies = getPublicCaseStudies(studies);

  return studies.map((study) => {
    const publicIndex = publicStudies.findIndex((item) => item.id === study.id);

    return {
      params: { slug: study.id },
      props: {
        study,
        previousStudy: publicIndex > 0 ? publicStudies[publicIndex - 1] : undefined,
        nextStudy: publicIndex >= 0 ? publicStudies[publicIndex + 1] : undefined
      }
    };
  });
}

const { study, previousStudy, nextStudy } = Astro.props;
const isPublicStudy = isPublicCaseStudy(study.id);
if (!import.meta.env.DEV && !isPublicStudy) return Astro.redirect("/#work", 302);

const usePaveTurntable = study.id === "designing-pave";
const useSynapseTurntable = study.id === "synapse-sys";
const hasTurntable = usePaveTurntable || useSynapseTurntable;
const transitionPoster = usePaveTurntable
  ? study.image
  : useSynapseTurntable
    ? "/case-studies/media/synapse-sys-card-turntable-poster.jpg"
    : undefined;
const caseTheme = study.id === "designing-pave"
  ? "pave"
  : ["synapse-sys", "designing-synapse-sys"].includes(study.id)
    ? "synapse"
    : undefined;
const caseMeta = [study.group, study.category ?? "case study", study.status, study.readTime]
  .filter(Boolean)
  .join(" / ");
const tagMeta = study.tags.length > 0 ? study.tags.join(" / ") : "";
const caseHeadings = getCaseStudyHeadings(study.body);
const hasReadingTools = caseHeadings.length > 1 || Boolean(study.walkthroughVideo);
const walkthroughPoster = study.walkthroughPoster ?? study.image;
const walkthroughLabel = study.walkthroughLabel ?? "Watch walkthrough";
const caseHref = (item: { id: string }) => `/case-studies/${item.id}/`;
const pageTitle = `${study.title} - Alexander Traykov`;
const metaDescription = study.summary || `${study.title} case study by Alexander Traykov.`;
const footerLinks = [
  { label: "All work", href: "/#work" },
  previousStudy ? { label: `Previous: ${previousStudy.title}`, href: caseHref(previousStudy) } : undefined,
  nextStudy ? { label: `Next: ${nextStudy.title}`, href: caseHref(nextStudy) } : undefined
].filter(Boolean);
const contactPromptByStudy: Record<string, { eyebrow: string; title: string; body: string }> = {
  "designing-pave": {
    eyebrow: "AI product work",
    title: "Building an AI product that has to survive the demo?",
    body: "Bring me the interaction, workflow, or trust knot. We can unpack it together in 30 focused minutes."
  },
  "synapse-sys": {
    eyebrow: "Complex interaction",
    title: "Making a complicated AI system feel dependable?",
    body: "Bring me the product model, graph, or failure state. We can unpack it together in 30 focused minutes."
  }
};
const contactPrompt = contactPromptByStudy[study.id] ?? {
  eyebrow: "Product design",
  title: "Working through a similarly messy product problem?",
  body: "Bring me the context and the awkward part. We can unpack it together in 30 focused minutes."
};
---

<!doctype html>
<html lang="en">
  <head>
    <SiteHead
      title={pageTitle}
      description={metaDescription}
      path={`/case-studies/${study.id}/`}
      image={study.image ?? "/og-image.png"}
      noindex={!isPublicStudy}
    />
    <script src="/page-transitions.js" defer></script>
  </head>
  <body data-page-type="case" data-case-id={study.id} data-case-theme={caseTheme}>

    <header class="site-nav site-nav--case">
      <a class="brand" href="/" aria-label="Alexander Traykov home">AT</a>
      <nav aria-label="Primary">
        <a href="/#work" aria-current="page" data-scramble>Work</a>
        <a href="/about/" data-scramble>About</a>
        <a href="/contact/" data-scramble>Contact</a>
      </nav>
      <ThemeToggle />
      <div class="case-progress" aria-hidden="true"><span></span></div>
    </header>

    <main id="top" class="case-page">
      <section class:list={["case-hero", hasTurntable && "case-hero--turntable"]} aria-labelledby="case-title">
        {transitionPoster && (
          <div class="case-transition-poster" data-case-transition-media aria-hidden="true">
            <img src={transitionPoster} alt="" decoding="async" />
          </div>
        )}
        {usePaveTurntable ? (
          <PaveTurntable
            class="case-hero-turntable"
            asciiClass="case-hero-turntable__ascii"
            renderSize={0.94}
            ariaLabel=""
          />
        ) : useSynapseTurntable ? (
          <SynapseSysTurntable
            class="case-hero-turntable"
            asciiClass="case-hero-turntable__ascii"
            renderSize={0.94}
            ariaLabel=""
          />
        ) : (
          <div class="ascii-stage compact-stage" data-ascii-shader>
            <canvas aria-hidden="true"></canvas>
            <pre aria-hidden="true" lang="bg"></pre>
          </div>
        )}

        <div class="case-hero-copy section-shell" data-reveal="rise" data-transition-copy>
          <nav class="case-breadcrumb" aria-label="Breadcrumb">
            <a href="/#work">Work</a>
            <span>{study.group}</span>
          </nav>
          <p class="section-kicker">{caseMeta}</p>
          <h1 id="case-title">{study.title}</h1>
          {study.summary && <p class="case-hero-summary">{study.summary}</p>}
          {tagMeta && <p class="case-hero-meta"><span>{tagMeta}</span></p>}
        </div>
      </section>

      <article class="case-study case-detail section-shell">
        <div class:list={["case-reader-layout", hasReadingTools && "case-reader-layout--with-tools"]}>
          <div class="case-body">
            {study.image && !usePaveTurntable && (
              <figure class="case-cover">
                <img src={study.image} alt="" loading="eager" />
              </figure>
            )}
            <div class="case-study-body" set:html={renderMarkdown(study.body)} />
          </div>

          {hasReadingTools && (
            <aside
              class="case-reading-tools"
              data-case-reading-tools
              data-reveal="fade"
              data-reveal-delay="240"
              aria-label="Case study reading tools"
            >
              <div class="case-reading-tools__status" data-case-progress-readout>READ [..........] 000%</div>
              <button class="case-reading-tools__close" type="button" data-case-reading-close aria-label="Hide reading tools">
                x
              </button>

              {study.walkthroughVideo && (
                <div class="case-walkthrough">
                  <button
                    class="case-walkthrough__trigger"
                    type="button"
                    data-case-walkthrough-open
                    aria-haspopup="dialog"
                    aria-label={`Play ${walkthroughLabel}`}
                  >
                    <span class="case-walkthrough__avatar" aria-hidden="true">
                      <video
                        src={study.walkthroughVideo}
                        muted
                        loop
                        playsinline
                        autoplay
                        preload="metadata"
                        poster={walkthroughPoster}
                      ></video>
                    </span>
                    <span class="case-walkthrough__copy">
                      <span>Skip read</span>
                      <strong>{walkthroughLabel}</strong>
                    </span>
                  </button>
                </div>
              )}

              {caseHeadings.length > 1 && (
                <nav class="case-toc" aria-label="On this case">
                  <p>On this case</p>
                  <ol>
                    {caseHeadings.map((heading) => (
                      <li class={`case-toc__item case-toc__item--depth-${heading.depth}`}>
                        <button type="button" data-case-target={heading.id} data-scramble data-scramble-label={heading.text}>
                          {heading.text}
                        </button>
                      </li>
                    ))}
                  </ol>
                </nav>
              )}
            </aside>
          )}
        </div>

        {study.walkthroughVideo && (
          <dialog class="case-walkthrough-modal" aria-labelledby="case-walkthrough-modal-title" data-case-walkthrough-modal>
            <div class="case-walkthrough-modal__header">
              <h2 id="case-walkthrough-modal-title">{walkthroughLabel}</h2>
              <button class="case-walkthrough-modal__close" type="button" data-case-walkthrough-close aria-label="Close video">
                x
              </button>
            </div>
            <video
              src={study.walkthroughVideo}
              controls
              playsinline
              preload="metadata"
              poster={walkthroughPoster}
              data-case-walkthrough-video
            ></video>
          </dialog>
        )}

        <CaseContactPrompt
          caseTitle={study.title}
          eyebrow={contactPrompt.eyebrow}
          title={contactPrompt.title}
          body={contactPrompt.body}
        />
      </article>

      <nav class="case-sibling-nav case-sibling-nav--bottom section-shell" aria-label="More case studies" data-reveal="rise">
        {previousStudy && (
          <a href={caseHref(previousStudy)} data-case-direction="previous">
            <span data-scramble data-scramble-label="Previous case">Previous case</span>
            <strong>{previousStudy.title}</strong>
          </a>
        )}
        {nextStudy && (
          <a href={caseHref(nextStudy)} data-case-direction="next">
            <span data-scramble data-scramble-label="Next case">Next case</span>
            <strong>{nextStudy.title}</strong>
          </a>
        )}
        {(!previousStudy || !nextStudy) && (
          <span class="case-sibling-nav__empty">More case studies coming soon</span>
        )}
      </nav>
    </main>

    <SiteFooter links={footerLinks} />

    <script is:inline src="/ascii-shader.js?v=case-pages-4"></script>
    {useSynapseTurntable && <script src="/synapse-mini-canvas.js" defer></script>}
    <script>
      import { registerTurntables } from "../../scripts/turntable-loader.js";

      registerTurntables(
        "[data-pave-turntable]",
        () => import("../../scripts/pave-symbol-turntable.js"),
        (module, root) => module.initializePaveTurntable(root)
      );
      registerTurntables(
        "[data-sasi-logo-turntable]",
        () => import("../../scripts/sasi-logo-turntable.js"),
        (module, root) => module.initializeSasiLogoTurntable(root)
      );
    </script>
    <script is:inline>
      (() => {
        const readingTools = document.querySelector("[data-case-reading-tools]");
        const closeReadingTools = document.querySelector("[data-case-reading-close]");
        const links = Array.from(document.querySelectorAll("[data-case-target]"));
        const sections = links
          .map((link) => document.getElementById(link.dataset.caseTarget || ""))
          .filter(Boolean);
        const bottomSiblingNav = document.querySelector(".case-sibling-nav--bottom");
        const walkthroughTrigger = document.querySelector("[data-case-walkthrough-open]");
        const walkthroughModal = document.querySelector("[data-case-walkthrough-modal]");
        const walkthroughClose = document.querySelector("[data-case-walkthrough-close]");
        const walkthroughVideo = walkthroughModal?.querySelector("[data-case-walkthrough-video]");
        const compactReadingTools = window.matchMedia("(max-width: 1180px)");

        const setReadingToolsVisible = (visible) => {
          document.body.classList.toggle("is-reading-tools-visible", visible);
        };

        let hideTimer = 0;
        const scheduleHide = () => {
          if (!compactReadingTools.matches) return;
          window.clearTimeout(hideTimer);
          hideTimer = window.setTimeout(() => setReadingToolsVisible(false), 1400);
        };

        const showWhileScrolling = () => {
          if (!readingTools || readingTools.dataset.dismissed === "true") return;
          if (
            compactReadingTools.matches &&
            bottomSiblingNav &&
            bottomSiblingNav.getBoundingClientRect().top <= window.innerHeight
          ) {
            window.clearTimeout(hideTimer);
            setReadingToolsVisible(false);
            return;
          }
          setReadingToolsVisible(true);
          scheduleHide();
        };

        if (readingTools && !compactReadingTools.matches) {
          setReadingToolsVisible(true);
        }

        compactReadingTools.addEventListener("change", () => {
          window.clearTimeout(hideTimer);
          if (!readingTools || readingTools.dataset.dismissed === "true") return;
          setReadingToolsVisible(!compactReadingTools.matches);
        });

        const activate = (id) => {
          links.forEach((link) => {
            if (link.dataset.caseTarget === id) {
              link.setAttribute("aria-current", "true");
            } else {
              link.removeAttribute("aria-current");
            }
          });
        };

        const updateActiveSection = () => {
          let active = sections[0];
          for (const section of sections) {
            if (section.getBoundingClientRect().top <= 132) {
              active = section;
            } else {
              break;
            }
          }
          if (active) activate(active.id);
        };

        if (links.length > 0) {
          updateActiveSection();
          window.addEventListener("scroll", () => {
            updateActiveSection();
            showWhileScrolling();
          }, { passive: true });
          window.addEventListener("resize", updateActiveSection);

          links.forEach((link) => {
            link.addEventListener("click", () => {
              const target = document.getElementById(link.dataset.caseTarget || "");
              target?.scrollIntoView({ behavior: "smooth", block: "start" });
            });
          });
        } else if (readingTools) {
          window.addEventListener("scroll", showWhileScrolling, { passive: true });
        }

        closeReadingTools?.addEventListener("click", () => {
          readingTools.dataset.dismissed = "true";
          setReadingToolsVisible(false);
        });

        walkthroughTrigger?.addEventListener("click", () => {
          if (!(walkthroughModal instanceof HTMLDialogElement)) return;
          walkthroughModal.showModal();
          walkthroughVideo?.play().catch(() => {});
        });

        walkthroughClose?.addEventListener("click", () => {
          if (walkthroughModal instanceof HTMLDialogElement) walkthroughModal.close();
        });

        walkthroughModal?.addEventListener("click", (event) => {
          if (event.target === walkthroughModal && walkthroughModal instanceof HTMLDialogElement) {
            walkthroughModal.close();
          }
        });

        walkthroughModal?.addEventListener("close", () => {
          walkthroughVideo?.pause();
          walkthroughTrigger?.focus();
          scheduleHide();
        });
      })();
    </script>
    <SiteAnalytics />
  </body>
</html>
