---
import PaveTurntable from "../../components/PaveTurntable.astro";
import SiteHead from "../../components/SiteHead.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import SynapseSysTurntable from "../../components/SynapseSysTurntable.astro";
import { getCaseStudies, getCaseStudyHeadings, renderMarkdown } from "../../lib/content";
import "../../styles/global.css";

export function getStaticPaths() {
  const studies = getCaseStudies();

  return studies.map((study, index) => ({
    params: { slug: study.id },
    props: {
      study,
      previousStudy: studies[index - 1],
      nextStudy: studies[index + 1]
    }
  }));
}

const { study, previousStudy, nextStudy } = Astro.props;
const usePaveTurntable = study.id === "designing-pave";
const useSynapseTurntable = study.id === "synapse-sys";
const hasTurntable = usePaveTurntable || useSynapseTurntable;
const caseTheme = ["synapse-sys", "designing-synapse-sys"].includes(study.id) ? "synapse" : undefined;
const caseMeta = [study.group, study.category ?? "case study", "WIP", study.readTime]
  .filter(Boolean)
  .join(" / ");
const tagMeta = study.tags.length > 0 ? study.tags.join(" / ") : "";
const caseHeadings = getCaseStudyHeadings(study.body);
const hasReadingTools = caseHeadings.length > 1 || Boolean(study.walkthroughVideo);
const walkthroughPoster = study.walkthroughPoster ?? study.image;
const walkthroughLabel = study.walkthroughLabel ?? "Watch walkthrough";
const caseHref = (item: { id: string }) => `/case-studies/${item.id}/`;
const pageTitle = `${study.title} WIP - Alexander Traykov`;
const metaDescription = `${study.title} case-study preview by Alexander Traykov.`;
const footerLinks = [
  { label: "All work", href: "/case-studies/" },
  previousStudy ? { label: `Previous: ${previousStudy.title}`, href: caseHref(previousStudy) } : undefined,
  nextStudy ? { label: `Next: ${nextStudy.title}`, href: caseHref(nextStudy) } : undefined
].filter(Boolean);
---

<!doctype html>
<html lang="en">
  <head>
    <SiteHead
      title={pageTitle}
      description={metaDescription}
      path={`/case-studies/${study.id}/`}
      image={study.image ?? "/og-image.png"}
      noindex
    />
    <script src="/page-transitions.js" defer></script>
  </head>
  <body data-case-theme={caseTheme}>
    <div class="noise" aria-hidden="true"></div>

    <header class="site-nav">
      <a class="brand" href="/" aria-label="Alexander Traykov home">AT</a>
      <nav aria-label="Primary">
        <a href="/case-studies/" data-scramble>Work</a>
        <a href="/about/" data-scramble>About</a>
        <a href="/playground" data-scramble>Playground</a>
        <a href="/svg-ascii-studio/" data-scramble>Studio</a>
      </nav>
    </header>

    <div class="case-progress" aria-hidden="true"><span></span></div>

    <main id="top" class="case-page">
      <section class:list={["case-hero", hasTurntable && "case-hero--turntable"]} aria-labelledby="case-title">
        {usePaveTurntable ? (
          <PaveTurntable
            class="case-hero-turntable"
            asciiClass="case-hero-turntable__ascii"
            renderSize={0.94}
            ariaLabel=""
          />
        ) : useSynapseTurntable ? (
          <SynapseSysTurntable
            class="case-hero-turntable"
            asciiClass="case-hero-turntable__ascii"
            renderSize={0.94}
            ariaLabel=""
          />
        ) : (
          <div class="ascii-stage compact-stage" data-ascii-shader>
            <canvas aria-hidden="true"></canvas>
            <pre aria-hidden="true" lang="bg"></pre>
          </div>
        )}

        <div class="case-hero-copy section-shell" data-reveal="rise">
          <nav class="case-breadcrumb" aria-label="Breadcrumb">
            <a href="/case-studies/">Work</a>
            <span>{study.group}</span>
          </nav>
          <p class="section-kicker">{caseMeta}</p>
          <h1 id="case-title">{study.title}</h1>
          {study.summary && <p class="case-hero-summary">{study.summary}</p>}
          {tagMeta && <p class="case-hero-meta"><span>{tagMeta}</span></p>}
        </div>
      </section>

      <nav class="case-sibling-nav section-shell" aria-label="Case study sequence" data-reveal="rise" data-reveal-delay="120">
        {previousStudy ? (
          <a href={caseHref(previousStudy)}>
            <span data-scramble data-scramble-label="Previous">Previous</span>
            <strong>{previousStudy.title}</strong>
            {previousStudy.image && (
              <span class="case-sibling-nav__preview" aria-hidden="true">
                <img src={previousStudy.image} alt="" loading="lazy" />
                <span>{previousStudy.summary}</span>
              </span>
            )}
          </a>
        ) : (
          <span class="case-sibling-nav__empty" aria-hidden="true"></span>
        )}
        <a class="case-sibling-nav__all" href="/case-studies/" data-scramble>All work</a>
        {nextStudy ? (
          <a href={caseHref(nextStudy)}>
            <span data-scramble data-scramble-label="Next">Next</span>
            <strong>{nextStudy.title}</strong>
            {nextStudy.image && (
              <span class="case-sibling-nav__preview" aria-hidden="true">
                <img src={nextStudy.image} alt="" loading="lazy" />
                <span>{nextStudy.summary}</span>
              </span>
            )}
          </a>
        ) : (
          <span class="case-sibling-nav__empty" aria-hidden="true"></span>
        )}
      </nav>

      <article class="case-study case-detail section-shell">
        <div class:list={["case-reader-layout", hasReadingTools && "case-reader-layout--with-tools"]}>
          <div class="case-body">
            {study.image && (
              <figure class="case-cover">
                <img src={study.image} alt="" loading="eager" />
              </figure>
            )}
            <div class="case-study-body" set:html={renderMarkdown(study.body)} />
          </div>

          {hasReadingTools && (
            <aside
              class="case-reading-tools"
              data-case-reading-tools
              data-reveal="fade"
              data-reveal-delay="240"
              aria-label="Case study reading tools"
            >
              <div class="case-reading-tools__status" data-case-progress-readout>READ [..........] 000%</div>
              <button class="case-reading-tools__close" type="button" data-case-reading-close aria-label="Hide reading tools">
                x
              </button>

              {study.walkthroughVideo && (
                <details class="case-walkthrough" data-case-walkthrough>
                  <summary>
                    <span class="case-walkthrough__avatar" aria-hidden="true">
                      <video
                        src={study.walkthroughVideo}
                        muted
                        loop
                        playsinline
                        autoplay
                        preload="metadata"
                        poster={walkthroughPoster}
                      ></video>
                    </span>
                    <span class="case-walkthrough__copy">
                      <span>Skip read</span>
                      <strong>{walkthroughLabel}</strong>
                    </span>
                  </summary>
                  <div class="case-walkthrough__panel">
                    <video src={study.walkthroughVideo} controls playsinline preload="metadata" poster={walkthroughPoster}></video>
                  </div>
                </details>
              )}

              {caseHeadings.length > 1 && (
                <nav class="case-toc" aria-label="On this case">
                  <p>On this case</p>
                  <ol>
                    {caseHeadings.map((heading) => (
                      <li class={`case-toc__item case-toc__item--depth-${heading.depth}`}>
                        <button type="button" data-case-target={heading.id} data-scramble data-scramble-label={heading.text}>
                          {heading.text}
                        </button>
                      </li>
                    ))}
                  </ol>
                </nav>
              )}
            </aside>
          )}
        </div>
      </article>

      <nav class="case-sibling-nav case-sibling-nav--bottom section-shell" aria-label="More case studies" data-reveal="rise">
        {previousStudy && (
          <a href={caseHref(previousStudy)}>
            <span data-scramble data-scramble-label="Previous case">Previous case</span>
            <strong>{previousStudy.title}</strong>
          </a>
        )}
        {nextStudy && (
          <a href={caseHref(nextStudy)}>
            <span data-scramble data-scramble-label="Next case">Next case</span>
            <strong>{nextStudy.title}</strong>
          </a>
        )}
      </nav>
    </main>

    <SiteFooter links={footerLinks} />

    <script is:inline src="/ascii-shader.js?v=case-pages-3"></script>
    {useSynapseTurntable && <script src="/synapse-mini-canvas.js" defer></script>}
    <script>
      import "../../scripts/pave-symbol-turntable.js";
      import "../../scripts/sasi-logo-turntable.js";
    </script>
    <script is:inline>
      (() => {
        const readingTools = document.querySelector("[data-case-reading-tools]");
        const closeReadingTools = document.querySelector("[data-case-reading-close]");
        const links = Array.from(document.querySelectorAll("[data-case-target]"));
        const sections = links
          .map((link) => document.getElementById(link.dataset.caseTarget || ""))
          .filter(Boolean);
        const walkthrough = document.querySelector("[data-case-walkthrough]");
        const panelVideo = walkthrough?.querySelector(".case-walkthrough__panel video");
        const compactReadingTools = window.matchMedia("(max-width: 1180px)");

        const setReadingToolsVisible = (visible) => {
          document.body.classList.toggle("is-reading-tools-visible", visible);
        };

        let hideTimer = 0;
        const scheduleHide = () => {
          if (!compactReadingTools.matches) return;
          window.clearTimeout(hideTimer);
          hideTimer = window.setTimeout(() => setReadingToolsVisible(false), 1400);
        };

        const showWhileScrolling = () => {
          if (!readingTools || readingTools.dataset.dismissed === "true") return;
          setReadingToolsVisible(true);
          scheduleHide();
        };

        if (readingTools && !compactReadingTools.matches) {
          setReadingToolsVisible(true);
        }

        compactReadingTools.addEventListener("change", () => {
          window.clearTimeout(hideTimer);
          if (!readingTools || readingTools.dataset.dismissed === "true") return;
          setReadingToolsVisible(!compactReadingTools.matches);
        });

        const activate = (id) => {
          links.forEach((link) => {
            if (link.dataset.caseTarget === id) {
              link.setAttribute("aria-current", "true");
            } else {
              link.removeAttribute("aria-current");
            }
          });
        };

        const updateActiveSection = () => {
          let active = sections[0];
          for (const section of sections) {
            if (section.getBoundingClientRect().top <= 132) {
              active = section;
            } else {
              break;
            }
          }
          if (active) activate(active.id);
        };

        if (links.length > 0) {
          updateActiveSection();
          window.addEventListener("scroll", () => {
            updateActiveSection();
            showWhileScrolling();
          }, { passive: true });
          window.addEventListener("resize", updateActiveSection);

          links.forEach((link) => {
            link.addEventListener("click", () => {
              const target = document.getElementById(link.dataset.caseTarget || "");
              target?.scrollIntoView({ behavior: "smooth", block: "start" });
            });
          });
        } else if (readingTools) {
          window.addEventListener("scroll", showWhileScrolling, { passive: true });
        }

        closeReadingTools?.addEventListener("click", () => {
          readingTools.dataset.dismissed = "true";
          setReadingToolsVisible(false);
          if (walkthrough) walkthrough.open = false;
          panelVideo?.pause();
        });

        walkthrough?.addEventListener("toggle", () => {
          if (walkthrough.open) {
            setReadingToolsVisible(true);
            panelVideo?.play().catch(() => {});
          } else {
            panelVideo?.pause();
            scheduleHide();
          }
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape" && walkthrough?.open) {
            walkthrough.open = false;
          }
        });
      })();
    </script>
  </body>
</html>
