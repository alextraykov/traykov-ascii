---
import SiteHead from "../../components/SiteHead.astro";
import { getCaseStudies } from "../../lib/content";
import "../../styles/global.css";

export function getStaticPaths() {
  return getCaseStudies().map((study) => ({
    params: { slug: study.id },
    props: { study }
  }));
}

const { study } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SiteHead
      title={`${study.title} hidden - Alexander Traykov`}
      description="This case-study route is hidden while the public portfolio preview stays focused on WIP cards."
      path={`/case-studies/${study.id}/`}
      noindex
      refresh="0;url=/"
    />
  </head>
  <body>
    <main class="hidden-route" aria-label="Hidden case study">
      <a href="/">Return home</a>
    </main>
  </body>
</html>
