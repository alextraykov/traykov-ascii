---
import ProjectMark from "../../components/ProjectMark.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { getCaseStudies } from "../../lib/content";
import "../../styles/global.css";

const caseStudies = getCaseStudies();
const featuredIds = ["designing-pave", "synapse-sys", "pointlearn"];
const featuredCards = featuredIds
  .map((id) => caseStudies.find((study) => study.id === id))
  .filter((study): study is NonNullable<typeof study> => study !== undefined)
  .map((study) => ({
    ...study,
    title:
      study.id === "designing-pave"
        ? "Designing Pave"
        : study.id === "synapse-sys"
          ? "Synapse-Sys"
          : study.title
  }));
const oldWorkCards = caseStudies.filter((study) => study.group === "Old work");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Case Studies - Alexander Traykov</title>
    <meta
      name="description"
      content="Separate product design case-study pages for Alexander Traykov's Quickbase and Pave work."
    />
    <script src="/page-transitions.js" defer></script>
  </head>
  <body>
    <div class="noise" aria-hidden="true"></div>

    <header class="site-nav">
      <a class="brand" href="/#top" aria-label="Alexander Traykov home">AT</a>
      <nav aria-label="Primary">
        <a href="/#work">Work</a>
        <a href="/about/">About</a>
        <a href="/playground">Playground</a>
        <a href="/svg-ascii-studio/">Studio</a>
      </nav>
    </header>

    <main id="top">
      <section class="case-hero case-index-hero" aria-labelledby="cases-title">
        <div class="ascii-stage compact-stage" data-ascii-shader>
          <canvas aria-hidden="true"></canvas>
          <pre aria-hidden="true" lang="bg"></pre>
        </div>
        <div class="case-hero-copy section-shell">
          <a class="case-back" href="/#work">Back to portfolio</a>
          <p class="section-kicker">Work index</p>
          <h1 id="cases-title">Case studies</h1>
          <p>Selected product stories and archived projects rewritten as case studies.</p>
        </div>
      </section>

      <section class="work case-index-grid section-shell" aria-label="Case-study index">
        <div class="section-heading">
          <p class="section-kicker">Selected work</p>
          <h2>Current portfolio pass.</h2>
        </div>
        <div class="project-grid">
          {featuredCards.map((study, index) => (
            <details class:list={["project-card", "project-card--expandable", "project-card--construction", study.id === "synapse-sys" && "project-card--synapse-sys", study.id === "synapse-sys" && "project-card--synapsis"]}>
              <summary class="project-card__body" aria-label={`${study.title} case study preview`}>
                <ProjectMark group={study.group} title={study.title} />
                <div class="project-copy">
                  <span class="project-index">{String(index + 1).padStart(2, "0")} / {study.group}</span>
                  <h3>{study.title}</h3>
                  {study.summary && <p>{study.summary}</p>}
                  <span class="construction-status">Preview only</span>
                  <span class="project-card__toggle" aria-hidden="true">Expand</span>
                </div>
              </summary>
              <div class="project-card__expanded">
                <dl class="project-card__meta">
                  {study.role && (
                    <div>
                      <dt>Role</dt>
                      <dd>{study.role}</dd>
                    </div>
                  )}
                  {study.year && (
                    <div>
                      <dt>Year</dt>
                      <dd>{study.year}</dd>
                    </div>
                  )}
                  {study.readTime && (
                    <div>
                      <dt>Read</dt>
                      <dd>{study.readTime}</dd>
                    </div>
                  )}
                </dl>
                {study.tags.length > 0 && (
                  <p class="project-card__tags">{study.tags.join(" / ")}</p>
                )}
                <a class="project-card__link" href={study.href}>Open case study</a>
              </div>
            </details>
          ))}
        </div>
      </section>

      <section class="work case-index-grid section-shell" aria-labelledby="old-work-title">
        <div class="section-heading">
          <p class="section-kicker">Old work</p>
          <h2 id="old-work-title">Archived projects from the old projects page.</h2>
        </div>

        <div class="project-grid">
          {oldWorkCards.map((study, index) => (
            <details class="project-card project-card--expandable project-card--construction">
              <summary class="project-card__body" aria-label={`${study.title} archived case study preview`}>
                <ProjectMark group={study.group} title={study.title} />
                <div class="project-copy">
                  <span class="project-index">{String(index + 1).padStart(2, "0")} / Old work</span>
                  <h3>{study.title}</h3>
                  {study.summary && <p>{study.summary}</p>}
                  <span class="construction-status">Archived preview</span>
                  <span class="project-card__toggle" aria-hidden="true">Expand</span>
                </div>
              </summary>
              <div class="project-card__expanded">
                <dl class="project-card__meta">
                  {study.role && (
                    <div>
                      <dt>Role</dt>
                      <dd>{study.role}</dd>
                    </div>
                  )}
                  {study.year && (
                    <div>
                      <dt>Year</dt>
                      <dd>{study.year}</dd>
                    </div>
                  )}
                  {study.readTime && (
                    <div>
                      <dt>Read</dt>
                      <dd>{study.readTime}</dd>
                    </div>
                  )}
                </dl>
                {study.tags.length > 0 && (
                  <p class="project-card__tags">{study.tags.join(" / ")}</p>
                )}
                <a class="project-card__link" href={study.href}>Open case study</a>
              </div>
            </details>
          ))}
        </div>
      </section>
    </main>

    <SiteFooter links={[{ label: "Home", href: "/#top" }]} />

    <script is:inline src="/ascii-shader.js?v=static-project-mark-2"></script>
    <script>
      import "../../scripts/synapse-card-scramble.js";

      const loadProjectTurntables = () => {
        import("../../scripts/pave-symbol-turntable.js");
        import("../../scripts/sasi-logo-turntable.js");
      };
      let turntablesQueued = false;
      const queueProjectTurntables = () => {
        if (turntablesQueued) return;
        turntablesQueued = true;
        loadProjectTurntables();
      };

      document.querySelector(".project-grid")?.addEventListener("pointerenter", queueProjectTurntables, {
        once: true
      });
      document.querySelector(".project-grid")?.addEventListener("focusin", queueProjectTurntables, {
        once: true
      });
      window.setTimeout(queueProjectTurntables, 4200);

      if ("requestIdleCallback" in window) {
        window.requestIdleCallback(() => {
          if (window.scrollY > window.innerHeight * 0.35) queueProjectTurntables();
        }, { timeout: 2600 });
      }
    </script>
  </body>
</html>
