---
import ProjectCard from "../../components/ProjectCard.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { getCaseStudies } from "../../lib/content";
import "../../styles/global.css";

const caseStudies = getCaseStudies();
const previewOnly = (study: NonNullable<ReturnType<typeof caseStudies.find>>) => ({
  ...study,
  href: `/case-studies/#${study.id}`,
  status: "WIP"
});

const paveIds = ["designing-pave", "building-pave-environment"];
const aiProductIds = ["synapse-sys", "pointlearn"];
const systemsIds = [
  "pipelines",
  "alm-environments",
  "connection-central",
  "design-systems-ai-practice",
  "design-leadership-operations",
  "foundations-2022-2024",
  "ai-surfaces"
];

const byId = (id: string) => caseStudies.find((study) => study.id === id);
const compact = (items: Array<ReturnType<typeof byId>>) =>
  items.filter((study): study is NonNullable<typeof study> => Boolean(study));

const paveCards = compact(paveIds.map(byId)).map(previewOnly);
const aiProductCards = compact(aiProductIds.map(byId)).map(previewOnly);
const systemsCards = compact(systemsIds.map(byId)).map(previewOnly);
const oldWorkCards = caseStudies.filter((study) => study.group === "Old work").map(previewOnly);

const sections = [
  {
    id: "pave",
    kicker: "Pave case studies",
    title: "WIP previews, not public reads.",
    intro:
      "The product and design-engineering stories stay preserved behind the gate. Deep evidence stays inside case studies until this pass is ready.",
    cards: paveCards
  },
  {
    id: "ai-product",
    kicker: "AI product studies",
    title: "AI product previews are WIP.",
    intro:
      "Recent AI product work is visible as a hiring preview only; full narratives remain gated while the Pave and PointLearn MP4 previews are prepared.",
    cards: aiProductCards
  },
  {
    id: "systems",
    kicker: "Product systems leadership",
    title: "Systems work is gated for now.",
    intro:
      "Enterprise systems, platform patterns, design operations, and AI-surface explorations stay listed without exposing unfinished writeups.",
    cards: systemsCards
  },
  {
    id: "archive",
    kicker: "Archive",
    title: "Older portfolio pieces stay preserved.",
    intro: "Older work remains in the repository, but the public site treats it as WIP preview material instead of accessible case-study content.",
    cards: oldWorkCards
  }
].filter((section) => section.cards.length > 0);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Work - Alexander Traykov</title>
    <meta
      name="description"
      content="Product design case-study index for Alexander Traykov, organized by Pave case studies, AI product studies, systems leadership, and archived work."
    />
    <script src="/page-transitions.js" defer></script>
  </head>
  <body>
    <div class="noise" aria-hidden="true"></div>

    <header class="site-nav">
      <a class="brand" href="/" aria-label="Alexander Traykov home">AT</a>
      <nav aria-label="Primary">
        <a href="/case-studies/" data-scramble>Work</a>
        <a href="/about/" data-scramble>About</a>
        <a href="/playground" data-scramble>Playground</a>
        <a href="/svg-ascii-studio/" data-scramble>Studio</a>
      </nav>
    </header>

    <main id="top">
      <section class="case-hero case-index-hero" aria-labelledby="cases-title">
        <div class="ascii-stage compact-stage" data-ascii-shader>
          <canvas aria-hidden="true"></canvas>
          <pre aria-hidden="true" lang="bg"></pre>
        </div>

        <div class="case-hero-copy section-shell">
          <nav class="case-breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span>Work</span>
          </nav>
          <p class="section-kicker">Work index</p>
          <h1 id="cases-title">Portfolio map</h1>
          <p>
            A hiring-manager preview path: strongest Pave work first, current AI product judgment second,
            systems leadership after. Deep evidence stays inside case studies until the WIP gate opens.
          </p>
        </div>
      </section>

      <nav class="work-directory section-shell" aria-label="Work sections" data-reveal-group>
        {sections.map((section) => (
          <a href={`#${section.id}`}>
            <span>{section.kicker}</span>
            <strong>{section.cards.length}</strong>
          </a>
        ))}
      </nav>

      <div class="case-index-sections">
        {sections.map((section) => (
          <section
            id={section.id}
            class="work case-index-grid section-shell"
            aria-labelledby={`${section.id}-title`}
            data-reveal="rise"
          >
            <div class="section-heading" data-reveal="fade">
              <p class="section-kicker">{section.kicker}</p>
              <h2 id={`${section.id}-title`}>{section.title}</h2>
              <p>{section.intro}</p>
            </div>

            <div class="project-grid" data-reveal-group>
              {section.cards.map((study, index) => (
                  <ProjectCard study={study} index={index} eyebrow={section.kicker} action="WIP / preview only" />
              ))}
            </div>
          </section>
        ))}
      </div>
    </main>

    <SiteFooter links={[{ label: "Home", href: "/" }]} />

    <script is:inline src="/ascii-shader.js?v=static-project-mark-3"></script>
    <script>
      import "../../scripts/synapse-card-scramble.js";

      const loadProjectTurntables = () => {
        import("../../scripts/pave-symbol-turntable.js");
        import("../../scripts/sasi-logo-turntable.js");
      };

      let turntablesQueued = false;
      const queueProjectTurntables = () => {
        if (turntablesQueued) return;
        turntablesQueued = true;
        loadProjectTurntables();
      };

      document.querySelector(".case-index-sections")?.addEventListener("pointerenter", queueProjectTurntables, {
        once: true
      });
      document.querySelector(".case-index-sections")?.addEventListener("focusin", queueProjectTurntables, {
        once: true
      });
      window.setTimeout(queueProjectTurntables, 3200);
    </script>
  </body>
</html>
