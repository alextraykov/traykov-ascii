---
import SiteAnalytics from "../components/SiteAnalytics.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHead from "../components/SiteHead.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import "../styles/global.css";

---

<!doctype html>
<html lang="en">
  <head>
    <SiteHead
      title="Contact Alexander Traykov"
      description="Send Alexander Traykov a message or book a call."
      path="/contact/"
    />
    <script src="/page-transitions.js" defer></script>
  </head>
  <body data-page-type="contact">
    <header class="site-nav">
      <a class="brand" href="/" aria-label="Alexander Traykov home">AT</a>
      <nav aria-label="Primary">
        <a href="/#work" data-scramble>Work</a>
        <a href="/about/" data-scramble>About</a>
        <a href="/contact/" aria-current="page" data-scramble>Contact</a>
      </nav>
      <ThemeToggle />
    </header>

    <main id="top" class="contact-page">
      <section class="contact-hero section-shell" aria-labelledby="contact-title">
        <div class="contact-hero__copy" data-reveal="rise">
          <p class="section-kicker">Contact</p>
          <h1 id="contact-title">Start with a message.</h1>
          <p>
            It goes to <a href="mailto:hi@traykov.cc">hi@traykov.cc</a>. I usually reply in
            half a day or less.
          </p>
        </div>

        <div class="contact-layout" data-reveal-group>
          <form
            class="contact-form"
            action="mailto:hi@traykov.cc"
            method="get"
            enctype="text/plain"
            data-contact-form
          >
            <div class="contact-form__heading">
              <span>01 / Write</span>
              <h2>Tell me what you’re working on.</h2>
            </div>

            <label>
              <span>Name</span>
              <input type="text" name="name" autocomplete="name" required />
            </label>

            <label>
              <span>Email</span>
              <input type="email" name="email" autocomplete="email" required />
            </label>

            <label>
              <span>Message</span>
              <textarea name="message" rows="7" required></textarea>
            </label>

            <div class="contact-form__submit">
              <p>Opens your email app with the message ready.</p>
              <button
                type="submit"
                data-ascii-action="primary"
                data-ascii-stream
                data-ascii-burst
              >
                <span data-scramble data-scramble-label="Write email">Write email</span>
                <span aria-hidden="true">↗</span>
              </button>
            </div>
          </form>

          <aside class="contact-call" aria-labelledby="contact-call-title">
            <span>02 / Talk</span>
            <div>
              <h2 id="contact-call-title">Book a call</h2>
              <p>Thirty minutes. No pitch, no pressure.</p>
            </div>
            <button
              type="button"
              data-booking-modal-open
              data-ascii-action="inverse"
              data-ascii-stream
              data-ascii-burst
            >
              <span data-scramble data-scramble-label="Book a call">Book a call</span>
              <span aria-hidden="true">+</span>
            </button>
          </aside>
        </div>
      </section>
    </main>

    <SiteFooter />

    <script>
      document.querySelectorAll("[data-contact-form]").forEach((form) => {
        if (!(form instanceof HTMLFormElement)) return;

        form.addEventListener("submit", (event) => {
          event.preventDefault();

          const data = new FormData(form);
          const name = String(data.get("name") ?? "").trim();
          const email = String(data.get("email") ?? "").trim();
          const message = String(data.get("message") ?? "").trim();
          const subject = `Website note from ${name}`;
          const body = [`Name: ${name}`, `Email: ${email}`, "", message].join("\n");

          window.location.href = `mailto:hi@traykov.cc?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
        });
      });
    </script>
    <SiteAnalytics />
  </body>
</html>
