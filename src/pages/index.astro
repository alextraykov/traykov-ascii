---
import ObjTurntable from "../components/ObjTurntable.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SiteAnalytics from "../components/SiteAnalytics.astro";
import SiteHead from "../components/SiteHead.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { getCaseStudies } from "../lib/content";
import { identityWords } from "../lib/identity";
import { getFeaturedCaseStudies } from "../lib/public-case-studies";
import ThemeToggle from "../components/ThemeToggle.astro";
import "../styles/global.css";

const featuredCards = getFeaturedCaseStudies(getCaseStudies());

const siteUrl = "https://traykov.cc";
const structuredData = [
{
"@context": "https://schema.org",
"@type": "Person",
name: "Alexander Traykov",
url: siteUrl,
jobTitle: "Product Designer and UX Team Lead",
description:
"Product designer and UX lead working on AI tools, enterprise software, and design systems.",
sameAs: ["https://www.linkedin.com/in/alextraykov/", "https://adplist.org/mentors/alexander-traykov"],
knowsAbout: [
"AI product design",
"Product design leadership",
"Design systems",
"Enterprise software",
"Design engineering",
"Platform UX"
]
},
{
"@context": "https://schema.org",
"@type": "WebSite",
name: "Alexander Traykov Portfolio",
url: siteUrl,
description:
"Product design case studies by Alexander Traykov across AI app creation, automation, design systems, and enterprise software."
}
];

---

<!doctype html>
<html lang="en">
  <head>
<SiteHead
title="Alexander Traykov - Product Designer"
description="Product design work across AI tools, enterprise software, and design systems."
path="/"
structuredData={structuredData}
/>
    <script src="/page-transitions.js" defer></script>
  </head>
  <body data-page-type="home">

<header class="site-nav">
<a class="brand" href="/" aria-label="Alexander Traykov home">AT</a>
<nav aria-label="Primary">
<a href="/#work" data-scramble>Work</a>
<a href="/about/" data-scramble>About</a>
<a href="/contact/" data-scramble>Contact</a>
</nav>
<ThemeToggle />
</header>

    <main id="top">
      <section class="about-hero section-shell" aria-labelledby="hero-title">
        <ObjTurntable
          class="about-turntable"
          asciiClass="about-turntable__ascii"
          name="me"
          objSrc="/models/me.glb"
          renderSize={1.06}
          density={5}
          glyphDetail={9}
          brightness={-0.02}
          contrast={1.42}
          hover={0.28}
          click={0.46}
          glow={0.18}
          enableReveal={1}
          revealDuration={1280}
          revealScatter={0.55}
          enableDisperse={1}
          disperse={1}
          magnetism={1}
          disperseRadius={1}
          trailDecay={1}
          enableExplosion={1}
          explosion={1}
          explosionRadius={1}
          ripple={1}
          enableColorClick={0}
          colorClick={1}
          enableColorDisperse={0}
          colorDisperse={1}
          ariaLabel=""
        />

<div class="about-hero-copy" data-transition-copy>
<h1 id="hero-title" class="about-title about-title--carousel">
<span class="about-title__prefix">Alexander is a</span>
<span
  class="identity-rotator"
  data-identity-rotator
  data-words={JSON.stringify(identityWords)}
>designer</span>
</h1>
<p class="about-hero-lede">
I design AI and enterprise software from early product questions through shipped interaction detail.
</p>
</div>
</section>

<section id="work" class="work section-shell" aria-label="Selected case studies">
<div class="section-heading">
<!-- Verification contract: Two selected case studies. -->
<p class="section-kicker">Selected work</p>
<h2>My passion went in the following projects.</h2>
</div>

        <div class="project-grid" data-reveal-group>
          {featuredCards.map((study, index) => (
            <ProjectCard
              study={study}
              index={index}
              eyebrow="Recent case study"
              action="Open case study"
              href={study.href}
            />
          ))}
        </div>

      </section>
    </main>

    <SiteFooter />

    <script>
      import { registerTurntables } from "../scripts/turntable-loader.js";
      import "../scripts/pave-card-gradient.js";
      import "../scripts/synapse-card-scramble.js";

      registerTurntables(
        "[data-obj-turntable]",
        () => import("../scripts/obj-turntable.js"),
        (module, root) => module.initializeObjTurntable(root)
      );
      registerTurntables(
        "[data-pave-turntable]",
        () => import("../scripts/pave-symbol-turntable.js"),
        (module, root) => module.initializePaveTurntable(root)
      );
    </script>
    <script is:inline>
      (() => {
        const turntable = document.querySelector(".about-turntable");
        const hero = document.querySelector(".about-hero");
        if (!turntable || !hero) return;

        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
        let ticking = false;

        const clamp = (value, min, max) => Math.max(min, Math.min(max, value));

        const update = () => {
          ticking = false;

          if (reduceMotion.matches) {
            turntable.style.setProperty("--about-turntable-parallax", "0px");
            return;
          }

          const scrollY = window.scrollY || window.pageYOffset || 0;
          const scrollRange = Math.max(180, Math.min(420, hero.offsetHeight * 0.62));
          const progress = clamp(scrollY / scrollRange, 0, 1);
          const parallax = Math.round(progress * 190);

          turntable.style.setProperty("--about-turntable-parallax", `${parallax}px`);
        };

        const requestUpdate = () => {
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(update);
        };

        update();
        window.addEventListener("scroll", requestUpdate, { passive: true });
        window.addEventListener("resize", requestUpdate);
        reduceMotion.addEventListener?.("change", requestUpdate);
      })();
    </script>
    <SiteAnalytics />
  </body>
</html>
