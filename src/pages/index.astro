---
import ObjTurntable from "../components/ObjTurntable.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { getCaseStudies } from "../lib/content";
import "../styles/global.css";

const identities = [
  "designer",
  "father",
  "husband",
  "son",
  "grandchild",
  "grappler",
  "pourover enjoyer",
  "walker",
  "writer",
  "yapper",
  "notebook hoarder",
  "coffee tinkerer",
  "mat philosopher",
  "Sofia dad",
  "question asker",
  "systems gardener",
  "slow runner",
  "early riser",
  "deadline negotiator",
  "friendly menace"
];

const featuredIds = ["designing-pave", "synapse-sys", "pointlearn"];
const caseStudies = getCaseStudies();
const previewOnly = (study: NonNullable<ReturnType<typeof caseStudies.find>>) => ({
  ...study,
  status: "WIP"
});
const featuredCards = featuredIds
  .map((id) => caseStudies.find((study) => study.id === id))
  .filter((study): study is NonNullable<typeof study> => study !== undefined)
  .map(previewOnly);

const aboutTurntableFallback = String.raw`
               ...............
          ....:::::::::::::::....
       ...::::++++*******++++::::...
     ..:::++***#############***++:::..
   .::++**####################**++::.
  .:++**#########*******########**++:.
 .:+**#######***+++++++++***#######**+:.
 :+**#####**+++:::::::::::+++**#####**+:
.+**####*++::::.........::::++*####**+.
:+*####*+:::....       ....:::+*####*+:
:+*####+::...   .:::::::.   ...::+####*+:
:+*####+::..   ::++***++::   ..::+####*+:
.+**###*+::.  :+*#####*+:  .::+*###**+.
 :+**####*+::.  :+*****+:  .::+*####**+:
 :+**#####*+:::.....:::++*#####**+:
 .:+**#######***+++***#######**+:.
  .:++**#################**++:.
    ..::++***#########***++::..
        ...::::+++++::::...
              .........
`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Alexander Traykov - Product Design Portfolio</title>
    <meta
      name="description"
      content="Product design portfolio of Alexander Traykov, focused on AI product surfaces, design systems, and Quickbase platform work."
    />
    <script src="/page-transitions.js" defer></script>
  </head>
  <body>
    <div class="noise" aria-hidden="true"></div>

    <header class="site-nav">
      <a class="brand" href="/" aria-label="Alexander Traykov home">AT</a>
      <nav aria-label="Primary">
        <a href="/" data-scramble>Home</a>
        <a href="/about/" data-scramble>About</a>
        <a href="/playground" data-scramble>Playground</a>
        <a href="/svg-ascii-studio/" data-scramble>Studio</a>
      </nav>
    </header>

    <main id="top">
      <section class="about-hero section-shell" aria-labelledby="hero-title">
        <ObjTurntable
          class="about-turntable"
          asciiClass="about-turntable__ascii"
          name="me"
          objSrc="/models/me.glb"
          renderSize={0.9}
          density={5}
          glyphDetail={9}
          brightness={-0.02}
          contrast={1.42}
          hover={0.28}
          click={0.46}
          glow={0.18}
          enableReveal={1}
          revealDuration={1280}
          revealScatter={0.55}
          enableDisperse={1}
          disperse={1}
          magnetism={1}
          disperseRadius={1}
          trailDecay={1}
          enableExplosion={1}
          explosion={1}
          explosionRadius={1}
          ripple={1}
          enableColorClick={0}
          colorClick={1}
          enableColorDisperse={0}
          colorDisperse={1}
          staticAscii={aboutTurntableFallback}
          ariaLabel=""
        />

        <div class="about-hero-copy">
          <p class="section-kicker">About</p>
          <h1 id="hero-title" class="about-title">
            <span class="about-title__prefix">Alexander is a</span>
            <span
              class="identity-rotator"
              data-identity-rotator
              data-words={JSON.stringify(identities)}
            >designer</span>
          </h1>
        </div>
      </section>

      <section class="work section-shell" aria-label="Case studies">
        <div class="section-heading">
          <p class="section-kicker">Case studies</p>
          <h2>Recent case studies.</h2>
        </div>

        <div class="project-grid" data-reveal-group>
          {featuredCards.map((study, index) => (
            <ProjectCard study={study} index={index} eyebrow="Recent case study" action="WIP / preview only" />
          ))}
        </div>

      </section>
    </main>

    <SiteFooter />

    <script>
      import "../scripts/obj-turntable.js";
      import "../scripts/synapse-card-scramble.js";

      const rotator = document.querySelector("[data-identity-rotator]");
      if (rotator) {
        const words = JSON.parse(rotator.getAttribute("data-words") || "[]");

        if (words.length) {
          let index = 0;
          const nextWord = () => {
            rotator.classList.remove("is-revealing");
            rotator.classList.add("is-reversing");

            window.setTimeout(() => {
              index = (index + 1) % words.length;
              rotator.textContent = words[index];
              rotator.classList.remove("is-reversing");
              rotator.classList.add("is-revealing");
            }, 260);
          };

          rotator.classList.add("is-revealing");
          window.setInterval(nextWord, 1350);
        }
      }

      const loadProjectTurntables = () => {
        import("../scripts/pave-symbol-turntable.js");
        import("../scripts/sasi-logo-turntable.js");
      };
      let turntablesQueued = false;
      const queueProjectTurntables = () => {
        if (turntablesQueued) return;
        turntablesQueued = true;
        loadProjectTurntables();
      };

      document.querySelector(".project-grid")?.addEventListener("pointerenter", queueProjectTurntables, {
        once: true
      });
      document.querySelector(".project-grid")?.addEventListener("focusin", queueProjectTurntables, {
        once: true
      });
      window.setTimeout(queueProjectTurntables, 4200);

      if ("requestIdleCallback" in window) {
        window.requestIdleCallback(() => {
          if (window.scrollY > window.innerHeight * 0.35) queueProjectTurntables();
        }, { timeout: 2600 });
      }
    </script>
    <script is:inline>
      (() => {
        const turntable = document.querySelector(".about-turntable");
        const hero = document.querySelector(".about-hero");
        if (!turntable || !hero) return;

        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
        let ticking = false;

        const clamp = (value, min, max) => Math.max(min, Math.min(max, value));

        const update = () => {
          ticking = false;

          if (reduceMotion.matches) {
            turntable.style.setProperty("--about-turntable-parallax", "0px");
            return;
          }

          const scrollY = window.scrollY || window.pageYOffset || 0;
          const scrollRange = Math.max(180, Math.min(420, hero.offsetHeight * 0.62));
          const progress = clamp(scrollY / scrollRange, 0, 1);
          const parallax = Math.round(progress * 190);

          turntable.style.setProperty("--about-turntable-parallax", `${parallax}px`);
        };

        const requestUpdate = () => {
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(update);
        };

        update();
        window.addEventListener("scroll", requestUpdate, { passive: true });
        window.addEventListener("resize", requestUpdate);
        reduceMotion.addEventListener?.("change", requestUpdate);
      })();
    </script>
  </body>
</html>
