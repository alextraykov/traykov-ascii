---
import ObjTurntable from "../components/ObjTurntable.astro";
import SiteAnalytics from "../components/SiteAnalytics.astro";
import SiteHead from "../components/SiteHead.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <SiteHead
      title="GLB 3D ASCII Turntable - Alexander Traykov"
      description="Imported GLB model rendered as a WebGL turntable with an ASCII filter."
      path="/obj-turntable/"
    />
    <script src="/page-transitions.js" defer></script>
  </head>
  <body class="pave-turntable-page">
    <header class="site-nav">
      <a class="brand" href="/" aria-label="Alexander Traykov home">AT</a>
      <nav aria-label="Primary">
        <a href="/#work" data-scramble>Work</a>
        <a href="/about/" data-scramble>About</a>
        <a href="/contact/" data-scramble>Contact</a>
      </nav>
      <ThemeToggle />
    </header>

    <ObjTurntable
      class="pave-turntable-stage"
      asciiClass="pave-turntable-ascii"
      name="me"
      objSrc="/models/me.glb"
      renderSize={0.66}
      density={5}
      glyphDetail={9}
      brightness={-0.02}
      contrast={1.42}
      click={0.46}
      glow={0.18}
      ariaLabel="Me GLB 3D ASCII turntable"
    />

    <aside class="pave-turntable-controls" aria-label="GLB ASCII controls">
      <div class="control-group pave-turntable-preview-select">
        <label for="turntable-preview">Preview</label>
        <select id="turntable-preview" data-turntable-preview-select>
          <option value="/obj-turntable/" selected>Me GLB</option>
          <option value="/pave-turntable/">PAVE</option>
          <option value="/sasi-turntable/">Personal logo</option>
          <option value="/synapse-turntable/">SynapseSys</option>
          <option value="/playground/">All previews</option>
        </select>
      </div>

      <div class="pave-turntable-panel">
        <div class="pave-turntable-tabs" role="tablist" aria-label="Turntable panel">
          <button type="button" class="is-active" id="obj-tab-settings" role="tab" aria-selected="true" aria-controls="obj-panel-settings" tabindex="0" data-obj-tab="settings">
            Copy
          </button>
          <button type="button" id="obj-tab-how" role="tab" aria-selected="false" aria-controls="obj-panel-how" tabindex="-1" data-obj-tab="how">
            How
          </button>
        </div>

        <div class="pave-turntable-panel-face is-active" id="obj-panel-settings" role="tabpanel" aria-labelledby="obj-tab-settings" data-obj-panel="settings">
          <div class="pave-turntable-settings">
            <span>Settings JSON</span>
            <textarea data-obj-settings readonly spellcheck="false"></textarea>
            <button type="button" data-obj-copy-settings>Copy settings JSON</button>
          </div>
        </div>

        <div class="pave-turntable-panel-face" id="obj-panel-how" role="tabpanel" aria-labelledby="obj-tab-how" data-obj-panel="how" hidden>
          <div class="turntable-process" aria-label="GLB to 3D ASCII turntable pipeline">
            <p>GLB to 3D ASCII</p>
            <svg viewBox="0 0 360 520" role="img" aria-label="GLB turntable rendering pipeline">
              <defs>
                <marker id="obj-process-arrow" markerWidth="10" markerHeight="8" refX="8" refY="4" orient="auto">
                  <path d="M0,0 L10,4 L0,8 Z" fill="currentColor"></path>
                </marker>
              </defs>
              <g class="node">
                <rect x="24" y="24" width="312" height="72"></rect>
                <text x="44" y="54">01 / Load GLB</text>
                <text x="44" y="78" class="mono">/models/me.glb</text>
              </g>
              <path class="arrow" d="M180 106 V142"></path>
              <g class="node">
                <rect x="24" y="152" width="312" height="72"></rect>
                <text x="44" y="182">02 / Normalize mesh</text>
                <text x="44" y="206" class="mono">center + scale in Three.js</text>
              </g>
              <path class="arrow" d="M180 234 V270"></path>
              <g class="node">
                <rect x="24" y="280" width="312" height="72"></rect>
                <text x="44" y="310">03 / Turntable light</text>
                <text x="44" y="334" class="mono">rotate mesh + shade surfaces</text>
              </g>
              <path class="arrow" d="M180 362 V398"></path>
              <g class="node">
                <rect x="24" y="408" width="312" height="72"></rect>
                <text x="44" y="438">04 / ASCII sample</text>
                <text x="44" y="462" class="mono">hidden WebGL to glyph grid</text>
              </g>
            </svg>
          </div>
        </div>
      </div>

      <label>
        <span>Speed <output data-obj-output="speed">0.24</output></span>
        <input type="range" min="0" max="1.2" step="0.01" value="0.24" data-obj-control="speed" />
      </label>
      <label>
        <span>Size <output data-obj-output="renderSize">0.66</output></span>
        <input type="range" min="0.2" max="3.2" step="0.01" value="0.66" data-obj-control="renderSize" />
      </label>
      <label>
        <span>Density <output data-obj-output="density">5</output></span>
        <input type="range" min="5" max="18" step="1" value="5" data-obj-control="density" />
      </label>
      <label>
        <span>Glyph detail <output data-obj-output="glyphDetail">9</output></span>
        <input type="range" min="2" max="9" step="1" value="9" data-obj-control="glyphDetail" />
      </label>
      <label>
        <span>Hover <output data-obj-output="hover">0.28</output></span>
        <input type="range" min="0" max="1" step="0.01" value="0.28" data-obj-control="hover" />
      </label>
      <label>
        <span>Click ripple <output data-obj-output="click">0.46</output></span>
        <input type="range" min="0" max="1" step="0.01" value="0.46" data-obj-control="click" />
      </label>
      <label>
        <span>Brightness <output data-obj-output="brightness">-0.02</output></span>
        <input type="range" min="-0.4" max="0.4" step="0.01" value="-0.02" data-obj-control="brightness" />
      </label>
      <label>
        <span>Contrast <output data-obj-output="contrast">1.42</output></span>
        <input type="range" min="0.5" max="3" step="0.01" value="1.42" data-obj-control="contrast" />
      </label>
      <label>
        <span>Glow <output data-obj-output="glow">0.18</output></span>
        <input type="range" min="0" max="0.9" step="0.01" value="0.18" data-obj-control="glow" />
      </label>
    </aside>

    <script>
      import { registerTurntables } from "../scripts/turntable-loader.js";
      import "../scripts/turntable-preview-select.js";

      registerTurntables(
        "[data-obj-turntable]",
        () => import("../scripts/obj-turntable.js"),
        (module, root) => module.initializeObjTurntable(root)
      );
    </script>
    <SiteAnalytics />
  </body>
</html>
