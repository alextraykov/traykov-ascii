---
import PaveTurntable from "../components/PaveTurntable.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>PAVE 3D Turntable - Alexander Traykov</title>
    <meta name="description" content="Extruded 3D PAVE symbol turntable rendered with Three.js." />
    <script src="/page-transitions.js" defer></script>
  </head>
  <body class="pave-turntable-page">
    <header class="site-nav">
      <a class="brand" href="/" aria-label="Back to portfolio">AT</a>
      <nav aria-label="Primary">
        <a href="/" data-scramble>Portfolio</a>
        <a href="/playground" data-scramble>Playground</a>
        <a href="/svg-ascii-studio/" data-scramble>Studio</a>
      </nav>
    </header>

    <PaveTurntable
      class="pave-turntable-stage"
      asciiClass="pave-turntable-ascii"
      controls
      ariaLabel="PAVE symbol 3D turntable"
    />

    <aside class="pave-turntable-controls" aria-label="PAVE ASCII controls">
      <div class="control-group pave-turntable-preview-select">
        <label for="turntable-preview">Preview</label>
        <select id="turntable-preview" data-turntable-preview-select>
          <option value="/pave-turntable/" selected>PAVE</option>
          <option value="/obj-turntable/">Me GLB</option>
          <option value="/sasi-turntable/">Personal logo</option>
          <option value="/synapse-turntable/">SynapseSys</option>
          <option value="/playground/">All previews</option>
        </select>
      </div>

      <div class="pave-turntable-panel">
        <div class="pave-turntable-tabs" role="tablist" aria-label="Turntable panel">
          <button type="button" class="is-active" role="tab" aria-selected="true" data-pave-tab="settings">
            Copy
          </button>
          <button type="button" role="tab" aria-selected="false" data-pave-tab="how">
            How
          </button>
        </div>

        <div class="pave-turntable-panel-face is-active" data-pave-panel="settings">
          <div class="pave-turntable-settings">
            <span>Settings JSON</span>
            <textarea data-pave-settings readonly spellcheck="false"></textarea>
            <button type="button" data-pave-copy-settings>Copy settings JSON</button>
          </div>
        </div>

        <div class="pave-turntable-panel-face" data-pave-panel="how" hidden>
          <div class="turntable-process" aria-label="SVG to 3D ASCII turntable pipeline">
            <p>SVG to 3D ASCII</p>
            <svg viewBox="0 0 360 520" role="img" aria-label="PAVE turntable rendering pipeline">
              <defs>
                <marker id="pave-process-arrow" markerWidth="10" markerHeight="8" refX="8" refY="4" orient="auto">
                  <path d="M0,0 L10,4 L0,8 Z" fill="currentColor"></path>
                </marker>
              </defs>
              <g class="node">
                <rect x="24" y="24" width="312" height="72"></rect>
                <text x="44" y="54">01 / Draw mark</text>
                <text x="44" y="78" class="mono">PAVE vector shapes</text>
              </g>
              <path class="arrow" d="M180 106 V142"></path>
              <g class="node">
                <rect x="24" y="152" width="312" height="72"></rect>
                <text x="44" y="182">02 / Build geometry</text>
                <text x="44" y="206" class="mono">extrude shapes in Three.js</text>
              </g>
              <path class="arrow" d="M180 234 V270"></path>
              <g class="node">
                <rect x="24" y="280" width="312" height="72"></rect>
                <text x="44" y="310">03 / Turntable light</text>
                <text x="44" y="334" class="mono">rotate mesh + shaded sides</text>
              </g>
              <path class="arrow" d="M180 362 V398"></path>
              <g class="node">
                <rect x="24" y="408" width="312" height="72"></rect>
                <text x="44" y="438">04 / ASCII sample</text>
                <text x="44" y="462" class="mono">hidden WebGL to glyph grid</text>
              </g>
            </svg>
          </div>
        </div>
      </div>

      <label>
        <span>Speed <output data-pave-output="speed">0.38</output></span>
        <input type="range" min="0" max="1.2" step="0.01" value="0.38" data-pave-control="speed" />
      </label>
      <label>
        <span>Size <output data-pave-output="renderSize">1.00</output></span>
        <input type="range" min="0.2" max="3.2" step="0.01" value="1" data-pave-control="renderSize" />
      </label>
      <label>
        <span>Depth <output data-pave-output="depth">64</output></span>
        <input type="range" min="8" max="140" step="1" value="64" data-pave-control="depth" />
      </label>
      <label>
        <span>Bevel <output data-pave-output="bevel">5.8</output></span>
        <input type="range" min="0" max="14" step="0.1" value="5.8" data-pave-control="bevel" />
      </label>
      <label>
        <span>Density <output data-pave-output="density">10</output></span>
        <input type="range" min="5" max="18" step="1" value="10" data-pave-control="density" />
      </label>
      <label>
        <span>Glyph detail <output data-pave-output="glyphDetail">4</output></span>
        <input type="range" min="2" max="9" step="1" value="4" data-pave-control="glyphDetail" />
      </label>
      <label>
        <span>Hover <output data-pave-output="hover">0.34</output></span>
        <input type="range" min="0" max="1" step="0.01" value="0.34" data-pave-control="hover" />
      </label>
      <label>
        <span>Brightness <output data-pave-output="brightness">0.00</output></span>
        <input type="range" min="-0.4" max="0.4" step="0.01" value="0" data-pave-control="brightness" />
      </label>
      <label>
        <span>Contrast <output data-pave-output="contrast">1.35</output></span>
        <input type="range" min="0.5" max="3" step="0.01" value="1.35" data-pave-control="contrast" />
      </label>
      <label>
        <span>Glow <output data-pave-output="glow">0.18</output></span>
        <input type="range" min="0" max="0.9" step="0.01" value="0.18" data-pave-control="glow" />
      </label>
    </aside>

    <script>
      import "../scripts/pave-symbol-turntable.js";
      import "../scripts/turntable-preview-select.js";
    </script>
  </body>
</html>
