---
import StudioWorkbench from "../../apps/svg-ascii-studio/src/components/StudioWorkbench.astro";
import SiteAnalytics from "../components/SiteAnalytics.astro";
import SiteHead from "../components/SiteHead.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import "../styles/global.css";
import "../../apps/svg-ascii-studio/src/styles/app.css";
---

<!doctype html>
<html lang="en">
  <head>
    <SiteHead
      title="ASCII Studio - Alexander Traykov"
      description="A portfolio-native mini tool for turning uploaded SVG marks into tuned 3D ASCII turntables and exportable outputs."
      path="/svg-ascii-studio/"
    />
    <script src="/page-transitions.js" defer></script>
  </head>
  <body class="portfolio-studio-page">
    <header class="site-nav">
      <a class="brand" href="/" aria-label="Alexander Traykov home">AT</a>
      <nav aria-label="Primary">
        <a href="/#work" data-scramble>Work</a>
        <a href="/about/" data-scramble>About</a>
        <a href="/contact/" data-scramble>Contact</a>
      </nav>
      <ThemeToggle />
    </header>

    <StudioWorkbench />
    <SiteAnalytics />
  </body>
</html>
