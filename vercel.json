{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "astro",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/case-studies",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/case-studies/",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/case-studies/:path*",
      "destination": "/",
      "permanent": false
    }
  ]
}
